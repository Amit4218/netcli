{
  "name": "ink-todo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx index.jsx",
    "build": "esbuild index.jsx --bundle --platform=node --format=esm  --outfile=dist/index.js",
    "package": "pkg dist/index.js",
    "alternate": "bun build index.jsx --compile --outfile net-cli --define process.env.NODE_ENV='production'"
  },
  "pkg": {
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "my-app": "./index.jsx"
  },
  "dependencies": {
    "@mishieck/ink-titled-box": "^0.4.2",
    "axios": "^1.13.5",
    "ink": "^6.8.0",
    "ink-picture": "^1.3.4",
    "ink-scroll-list": "^0.4.1",
    "ink-scroll-view": "^0.3.6",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "pkg": "^5.8.1",
    "tsx": "^4.21.0"
  }
}
